# DashScope API Key - 通义千问 API 密钥
DASHSCOPE_API_KEY=sk-your-api-key-here
QWEN_MODEL=qwen-plus-latest
QWEN_VISION_MODEL=qwen-vl-plus

# JWT Secret - 请使用安全随机值（建议 32 字节以上）
# 生成方法：python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=your-random-secret-here

# 前端允许来源（CORS）
ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://your-frontend.pages.dev

# 邮件服务配置（SMTP）
# 163 邮箱：smtp.163.com:465 (SSL)
# Gmail: smtp.gmail.com:587 (TLS)
# QQ 邮箱：smtp.qq.com:465 (SSL)
SMTP_HOST=smtp.163.com
SMTP_PORT=465
SMTP_USER=your-email@163.com
SMTP_PASS=your-auth-code  # 授权码，非登录密码
SMTP_USE_TLS=true

# OTP 配置
OTP_EXPIRE_MINUTES=5

# 测试模式：设置为 true 时，验证码固定为 666666（仅开发环境使用）
TEST_MODE=false

# 管理员密码哈希
# 生成方法：python -c "import bcrypt; print(bcrypt.hashpw('admin123'.encode(), bcrypt.gensalt()).decode())"
ADMIN_PASSWORD_HASH=$2b$12$your-bcrypt-hash-here

# 管理员 Token 有效期（分钟）
ADMIN_JWT_EXPIRE_MINUTES=120
